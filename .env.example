POSTGRES_DB=quotepro
POSTGRES_USER=quotepro
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

API_PUBLIC_PORT=4000
APP_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

MOCK_PAYMENTS=true
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_QUOTE_MODEL=gpt-5.3-chat-latest
OPENAI_QUOTE_FALLBACK_MODEL=gpt-5.3-chat-latest
OPENAI_REQUEST_TIMEOUT_MS=25000

S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# Google sign-in: comma-separated list of OAuth client IDs accepted as audience
# (web client + iOS client + Android client).
GOOGLE_OAUTH_CLIENT_IDS=

# WhatsApp Business Cloud API for OTP delivery (free to access; pay per OTP).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE_NAME=otp_code
WHATSAPP_OTP_TEMPLATE_LANGUAGE=en
WHATSAPP_API_VERSION=v22.0
WHATSAPP_API_BASE_URL=https://graph.facebook.com

# Firebase Admin credentials for provider push notifications. Prefer one of:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Set EXPOSE_OTP_CODE=true ONLY in local development to receive the OTP code in
# the API response when WhatsApp is not yet configured.
EXPOSE_OTP_CODE=false
